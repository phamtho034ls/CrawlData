# Copy this file to .env and fill in your API keys.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
# Optional: SerpAPI fallback for Google Trends (https://serpapi.com)
SERPAPI_API_KEY=
# Google Trends region/language (RSS + Playwright)
TRENDS_GEO=VN
TRENDS_HL=vi

# Whisper
WHISPER_DEVICE=auto
WHISPER_MODEL=base

# Scraper defaults (UI can override)
RECENCY_DAYS=7
MIN_VIEW_COUNT=50000
KEYWORD_COUNT=10
VIDEOS_PER_PLATFORM=5
VIDEOS_PER_KEYWORD_SEARCH=20
TOP_VIDEOS_PER_KEYWORD=10

# yt-dlp: use browser cookies for age-restricted / login-required YouTube (chrome, edge, firefox)
# Optional: chrome | edge | firefox — for age-restricted YouTube. Leave empty if Chrome is open
# (cookie DB locked) or downloads fail; yt-dlp will retry without cookies automatically.
YTDLP_COOKIES_FROM_BROWSER=
