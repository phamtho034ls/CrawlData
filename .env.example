# Copy this file to .env and fill in your API keys.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
# Optional: SerpAPI fallback for Google Trends (https://serpapi.com)
SERPAPI_API_KEY=
# Google Trends region/language (RSS + Playwright)
TRENDS_GEO=VN
TRENDS_HL=vi

# Whisper
WHISPER_DEVICE=auto
WHISPER_MODEL=base

# Scraper defaults (UI can override)
RECENCY_DAYS=7
MIN_VIEW_COUNT=50000
KEYWORD_COUNT=10
VIDEOS_PER_PLATFORM=5
VIDEOS_PER_KEYWORD_SEARCH=20
TOP_VIDEOS_PER_KEYWORD=10

# Module 3: max videos per run when scraping (0 = unlimited). Prefetched/saved lists process all links.
PIPELINE_MAX_VIDEOS=0

# yt-dlp — cookies (prefer YTDLP_COOKIES_FILE when Chrome is open / DB locked)
# Netscape cookies.txt export — most reliable on Windows
YTDLP_COOKIES_FILE=
# Optional: chrome | edge | firefox
YTDLP_COOKIES_FROM_BROWSER=
# Pause between downloads to reduce YouTube bot blocks (seconds)
YTDLP_DOWNLOAD_DELAY_SEC=4
# Player clients to try (comma-separated)
YTDLP_YOUTUBE_CLIENTS=android,web
